# ---------------------------------------------------------------------------
# terraform.tfvars — auto-generated by bootstrap_client.py
# DO NOT edit manually. All values below are injected at repo creation time.
# Open the bootstrap PR, review, then merge to trigger provisioning.
# ---------------------------------------------------------------------------

# ── Core Identity ────────────────────────────────────────────────────────────
client_name    = "{{CLIENT_NAME}}"
aws_account_id = "{{AWS_ACCOUNT_ID}}"
aws_region     = "{{AWS_REGION}}"
environment    = "{{ENVIRONMENT}}"
client_domain  = "{{CLIENT_DOMAIN}}"

# ── GitHub ───────────────────────────────────────────────────────────────────
github_org           = "{{GITHUB_ORG}}"
github_platform_repo = "{{GITHUB_PLATFORM_REPO}}"

# ── State Backend ─────────────────────────────────────────────────────────────
tf_state_bucket     = "{{TF_STATE_BUCKET}}"
tf_state_lock_table = "{{TF_STATE_LOCK_TABLE}}"

# ── Module Toggles ───────────────────────────────────────────────────────────
create_vpc              = true
create_iam              = true
create_eks              = true
create_monitoring       = true
create_security         = true
create_account_security = true  # set false only when multiple clients share one AWS account
create_kubernetes       = true

github_pat_ssm_path           = "/{{CLIENT_NAME}}/github/pat"
grafana_github_oauth_ssm_path = ""

# ── Existing Network (only needed if create_vpc = false) ─────────────────────
existing_vpc_id             = ""
existing_private_subnet_ids = []
existing_public_subnet_ids  = []

# ── VPC ───────────────────────────────────────────────────────────────────────
vpc_cidr           = "{{VPC_CIDR}}"
availability_zones = {{AVAILABILITY_ZONES}}

# ── EKS ───────────────────────────────────────────────────────────────────────
eks_cluster_version     = "{{EKS_CLUSTER_VERSION}}"
eks_node_instance_types = {{EKS_NODE_INSTANCE_TYPES}}
eks_node_desired_size   = {{EKS_NODE_DESIRED_SIZE}}
eks_node_min_size       = {{EKS_NODE_MIN_SIZE}}
eks_node_max_size       = {{EKS_NODE_MAX_SIZE}}
